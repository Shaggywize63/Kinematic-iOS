<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSApplicationCategoryType</key>
	<string></string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>We need camera access to capture selfies for attendance verification.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Continuous location is required for background visit verification and field safety.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>We need your location to verify store visits and attendance.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>We need gallery access if you choose to upload an existing photo.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Microphone access lets you ask KINI by voice on the AI chat.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Speech recognition transcribes what you say to KINI so the AI can respond to spoken questions.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>
	<!-- UIBackgroundModes:[location] removed temporarily so a free
	     Apple ID (without the paid Apple Developer Program) can sign
	     dev builds. The background-modes entitlement is gated behind
	     the paid program; with the key present, automatic signing
	     fails at install with "missing entitlement" / install retries
	     loop. Re-add when you upgrade to the paid program:
	         <key>UIBackgroundModes</key>
	         <array>
	             <string>location</string>
	         </array>
	     LocationTrackingService already skips
	     allowsBackgroundLocationUpdates on simulator and degrades to
	     foreground-only when the entitlement isn't present, so the
	     live-tracking ping pauses cleanly when the app is
	     backgrounded — no crash. -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
</dict>
</plist>
